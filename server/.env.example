# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://expenseApp:<password>@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=expenses

# CORS — the Vercel origin that is allowed to call this API
ALLOWED_ORIGIN=http://localhost:5173

# Password required to access /admin/categories. Pick something strong.
ADMIN_PASSWORD=change-me-to-something-real

# JWT signing secret. MUST be set in production to a random string of at least
# 32 bytes (256 bits). Generate one with: openssl rand -base64 48
# If unset, the server only starts in Development (using a bundled dev default);
# production refuses to boot, and the dev default is never accepted as a real value.
AUTH_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-bytes-long
AUTH_JWT_ISSUER=ledger
AUTH_JWT_AUDIENCE=ledger-clients